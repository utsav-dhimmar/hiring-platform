# App
PROJECT_NAME="HR Platform"
ENVIRONMENT="development"
DEBUG=True
SECRET_KEY=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Postgres
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=app

# Optional explicit database URL
# SQLALCHEMY_DATABASE_URI=postgresql+asyncpg://postgres:postgres@localhost/app

# CORS
BACKEND_CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173", "http://localhost:8000"]

# Resume uploads
RESUME_MAX_SIZE_MB=5
RESUME_UPLOAD_DIR=uploads/resumes

# Embeddings
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_VECTOR_DIM=1024
EMBEDDING_TRUNCATE_DIM=384
EMBEDDING_USE_INSTRUCTIONS=False

REDIS_URL=redis://redis:6379/0

VITE_API_URL=/api/v1
VITE_ADMIN_API_ENDPOINT="/admin"
VITE_RESUME_MAX_SIZE_MB=5
